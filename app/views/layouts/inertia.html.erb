<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Fallout" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="darkreader-lock">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/favicon.ico" sizes="32x32" type="image/x-icon">
    <link rel="icon" href="/soup.png" type="image/png">
    <link rel="apple-touch-icon" href="/soup.png">

    <link rel="preload" href="/fonts/Hells-Bells.otf" as="font" type="font/otf" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Google+Sans:ital,opsz,wght@0,17..18,400..700;1,17..18,400..700&family=Outfit:wght@100..900&display=swap" rel="stylesheet">

    <%= vite_client_tag %>
    <%= vite_react_refresh_tag %>
    <%= vite_stylesheet_tag "application" %>
    <%= vite_typescript_tag "inertia" %>
    <%= inertia_ssr_head %>
    <meta name="sentry-dsn" content="<%= ENV["SENTRY_DSN"] %>">
    <%= Sentry.get_trace_propagation_meta.html_safe %>
  </head>

  <body>
    <%= yield %>
  </body>
</html>
